{
  "extends": "../../packages/config/tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": false,
    "paths": {
      "@/*": ["./src/*"]
    },
    "rootDir": ".",
    "outDir": "./dist"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts"]
}
