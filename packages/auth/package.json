{
  "name": "@mma/auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./tanstack-server": {
      "types": "./src/tanstack-server.ts",
      "default": "./src/tanstack-server.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.6",
    "@mma/db": "workspace:*",
    "@mma/shared": "workspace:*",
    "better-auth": "^1.5.6",
    "zod": "^4.3.6"
  }
}
